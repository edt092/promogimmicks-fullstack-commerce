# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scraper (herramientas de desarrollo)
/promo-scraper/

# Claude Code local settings
/.claude/

# Data files (scraping y temporales)
/data/backups/
/data/*_scraped.json
/data/products_merged.json

# Python cache
__pycache__/
*.pyc
*.pyo

# Local SVG placeholders
/public/img/blog/*.svg

# Local Netlify folder
.netlify
